# Copy this file to .env and fill in your values

# Required: Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for WhatsApp (from Meta Developer Dashboard - completely free)
# Get these at: https://developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Choose any secret string — you'll paste this into the Meta webhook settings
WHATSAPP_VERIFY_TOKEN=wedding_verify_token
